# Discord Bot Configuration
DISCORD_BOT_TOKEN=your_discord_bot_token_here
TARGET_TEXT_CHANNEL_ID=123456789012345678
BOT_USER_ID=987654321098765432

# STT Configuration (Faster-Whisper)
WHISPER_MODEL_SIZE=base  # Options: tiny, base, small, medium, large-v2, large-v3
WHISPER_DEVICE=cpu  # Options: cuda, cpu - use cpu for Mac, cuda for NVIDIA GPUs
WHISPER_COMPUTE_TYPE=int8  # Options: float16, int8, int16 - default to int8 for CPU

# TTS Configuration (Piper)
PIPER_MODEL_PATH=/Users/ghively/.openclaw/voice-bridge/en_US-lessac-medium.onnx

# Voice Activity Detection
VAD_SILENCE_DURATION=1.5  # Seconds of silence to consider speech ended
VAD_AGGRESSIVENESS=3  # VAD aggressiveness (0-3, 3 being most aggressive)

# Audio Configuration
SAMPLE_RATE=48000  # Discord voice standard
# Note: Discord/Pycord uses stereo PCM internally; we convert to mono automatically
